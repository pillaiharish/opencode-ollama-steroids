# Copy to project.local.env and edit locally.
# Do not commit project.local.env.

PRODUCT_DIR=product-repo
PROJECT_SLUG=project-slug
PYTHON_BIN=.venv/bin/python
NODE_BIN=node
NPM_BIN=npm
OPENCODE_ATTACH_URL=

# Stable family prefixes. Supported launch scripts resolve the highest stable
# numeric :cloud ID exposed by the installed OpenCode CLI's refreshed Ollama
# catalog, then pin the verified exact pair for each prompt.
BUILDER_MODEL_FAMILY=minimax-m
REVIEWER_MODEL_FAMILY=glm-

# Optional strict exact cloud overrides. Leave unset to track the families above.
# BUILDER_MODEL=ollama/minimax-m3:cloud
# REVIEWER_MODEL=ollama/glm-5.2:cloud
